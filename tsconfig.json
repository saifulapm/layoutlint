{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "jsx": "react-jsx",
    "paths": {
      "@layoutlint/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "corpora/**/*.ts", "corpora/**/*.tsx"],
  "exclude": ["corpora/react"]
}
